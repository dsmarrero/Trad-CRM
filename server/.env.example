DATABASE_URL=postgresql://usuario:password@host:puerto/basededatos
JWT_SECRET=cambia_esto_por_un_secreto_seguro
PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# SMTP para recordatorios por email (resumen interno diario + recordatorios de impago a clientes)
# Si se dejan sin definir, los emails simplemente no se envían (se registra un aviso en consola).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Días de antelación para avisar de entregas próximas / días de retraso para avisar de impagos
RECORDATORIO_DIAS_ENTREGA=3
RECORDATORIO_DIAS_IMPAGO=15
